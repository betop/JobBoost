{
  "manifest_version": 3,
  "name": "Mail Traige",
  "version": "0.1.1",
  "description": "Auto-triage unread Gmail messages using Gmail + backend analysis.",
  "key": "",
  "action": {
    "default_title": "Mail Traige"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "src/service_worker.js",
    "type": "module"
  },
  "permissions": [
    "identity",
    "storage",
    "windows"
  ],
  "host_permissions": [
    "https://gmail.googleapis.com/*",
    "https://www.googleapis.com/*",
    "https://*.xano.io/*"
  ],
  "oauth2": {
    "client_id": "975375807122-9pnnhr722hqqr6eirjc3n32kp30mhkb9.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.modify"
    ]
  }
}
